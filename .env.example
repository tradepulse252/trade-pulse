# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=tradepulse
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tradepulse
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tradepulse:change_me_in_production@localhost:5432/tradepulse?schema=public

# ─── Redis (optional — leave empty for in-memory cache on Render) ──
REDIS_URL=

# ─── Backend ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
CORS_ORIGIN=http://localhost:3000

# ─── Binance Futures API (optional — public endpoints work without keys) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_BASE=https://fapi.binance.com
BINANCE_WS_BASE=wss://fstream.binance.com

# ─── Liquidity Filters (defaults exclude low-liquidity pairs) ──
MIN_VOLUME_USDT=1000000
MIN_OPEN_INTEREST_USDT=500000

# ─── Scoring Engine ──────────────────────────────────────────
SCORING_INTERVAL_MS=5000
OI_REFRESH_INTERVAL_MS=60000
METRICS_RETENTION_DAYS=30
OI_SPIKE_THRESHOLD_PCT=5
VOLUME_SPIKE_THRESHOLD_PCT=10
FUNDING_FLIP_THRESHOLD=0.0001

# ─── Email (Resend + Gmail SMTP) ───────────────────────────────
RESEND_API_KEY=
# Required on Render (free tier blocks SMTP). Use a verified domain, e.g. noreply@tradepulse.io
RESEND_FROM_ADDRESS=
EMAIL_FROM_NAME=Trade Pulse
EMAIL_FROM_ADDRESS=tradepulse252@gmail.com
EMAIL_REPLY_TO=tradepulse252@gmail.com
GMAIL_USER=tradepulse252@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_USE_SMTP=true
FRONTEND_URL=http://localhost:3000

# Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
# Gmail SMTP works locally. On Render free tier, SMTP is blocked — use Resend + verified domain.
# Resend test sender onboarding@resend.dev only delivers to your Resend account email.
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=Trade-Pulse

# Production URLs (fill after deploy)
NEXT_PUBLIC_API_URL=https://tradepulse-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://tradepulse-api.onrender.com
CORS_ORIGIN=https://your-app.vercel.app

# Neon PostgreSQL (free) — add ?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Auto-generated — use https://generate-secret.vercel.app/64
JWT_SECRET=

# Optional
REDIS_URL=
BINANCE_API_KEY=
BINANCE_API_SECRET=
