# ─── Firebase / Firestore ───────────────────────────────────
FIREBASE_PROJECT_ID=muchocoffee-tradepulse252
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIRESTORE_DATABASE_ID=(default)

# ─── Redis (optional) ───────────────────────────────────────
REDIS_URL=

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Binance Futures API (optional) ─────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_BASE=https://fapi.binance.com
BINANCE_WS_BASE=wss://fstream.binance.com
AGGREGATION_REFRESH_MS=90000
BINANCE_REST_FALLBACK_MS=120000
BINANCE_ENABLE_OI_BATCH=false

# ─── Liquidity Filters ──────────────────────────────────────
MIN_VOLUME_USDT=1000000
MIN_OPEN_INTEREST_USDT=500000

COINGLASS_API_KEY=
SCORING_INTERVAL_MS=10000
OI_REFRESH_INTERVAL_MS=300000
PERSIST_MARKET_DATA=false

# ─── Email (Resend recommended on cloud) ────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
EMAIL_FROM_NAME=Trade Pulse
EMAIL_FROM_ADDRESS=tradepulse252@gmail.com
EMAIL_REPLY_TO=tradepulse252@gmail.com
GMAIL_USER=tradepulse252@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_USE_SMTP=true

# ─── Admin seed (npm run db:seed) ───────────────────────────
ADMIN_EMAIL=admin@tradepulse.io
ADMIN_PASSWORD=Admin123!ChangeMe

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=Trade-Pulse

