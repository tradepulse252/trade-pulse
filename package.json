{
  "name": "trade-pulse",
  "version": "1.0.0",
  "private": true,
  "description": "Trade-Pulse — Real-Time Opportunity Scanner for Binance Futures",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "db:seed": "npm run db:seed -w backend",
    "firebase:deploy": "firebase deploy --only firestore",
    "deploy:northflank": "powershell -ExecutionPolicy Bypass -File scripts/deploy-northflank.ps1",
    "setup:northflank": "node scripts/setup-northflank-full.mjs",
    "setup:render": "node scripts/setup-render-full.mjs",
    "deploy:render": "powershell -ExecutionPolicy Bypass -File scripts/deploy-render.ps1",
    "setup:railway": "node scripts/setup-railway-full.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
